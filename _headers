# Security headers (Netlify / Cloudflare Pages "_headers" format).
# NOTE: On Vercel this file is ignored — vercel.json is the source of truth.
# Kept only for portability to Netlify/CF; keep the CSP in sync with vercel.json.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://esm.sh 'unsafe-inline'; style-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://esm.sh; frame-ancestors 'self'; base-uri 'self'
